BRIDGIFY_DB_HOST=
BRIDGIFY_DB_PORT=5432
BRIDGIFY_DB_NAME=
BRIDGIFY_DB_USER=
BRIDGIFY_DB_PASSWORD=
BRIDGIFY_DB_SSL=require
