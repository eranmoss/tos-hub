{
  "supplier_slug": "tiqets",
  "category": "EXPERIENCE",
  "auth_type": "BEARER",
  "base_url_sandbox": "https://api.api-tiqt-test.steq.it/v2",
  "base_url_production": "https://api.tiqets.com/v2",
  "documentation_url": "https://developers.tiqets.dev/",
  "rate_limit_rpm": 900,
  "order_limit_per_hour": 25,
  "default_currency": "EUR",
  "booking_flow": "TWO_STEP",
  "has_webhooks": true,
  "has_timeslots": true,
  "has_dynamic_pricing": true,
  "endpoints": {
    "search": { "method": "GET", "path": "/products" },
    "detail": { "method": "GET", "path": "/products/{productId}" },
    "checkout_info": { "method": "GET", "path": "/products/{productId}/checkout_information" },
    "availability": { "method": "GET", "path": "/products/{productId}/availability" },
    "variants": { "method": "GET", "path": "/products/{productId}/variants" },
    "book_reserve": { "method": "POST", "path": "/orders" },
    "book_confirm": { "method": "POST", "path": "/orders/{orderId}/confirm" },
    "get_order": { "method": "GET", "path": "/orders/{orderId}" },
    "get_tickets": { "method": "GET", "path": "/orders/{orderId}/tickets" },
    "cancel": { "method": "POST", "path": "/orders/{orderId}/cancel" },
    "list_orders": { "method": "GET", "path": "/orders" },
    "cities": { "method": "GET", "path": "/cities" },
    "tags": { "method": "GET", "path": "/tags" }
  },
  "field_mappings": {
    "id": "supplier_raw_ref",
    "title": "title",
    "description": "description",
    "duration": "duration_minutes",
    "price": "price.amount",
    "currency": "price.currency",
    "geolocation.lat": "location.latitude",
    "geolocation.lng": "location.longitude",
    "city_name": "location.city",
    "country_name": "location.country",
    "timezone": "location.timezone",
    "tag_ids": "category",
    "sale_status": "availability.status",
    "ratings.average": "rating",
    "ratings.total": "review_count",
    "cancellation.policy": "policies.cancellation"
  },
  "transforms": {
    "id": "toString",
    "duration": "hhmmssToMinutes",
    "sale_status": { "available": "CONFIRMED", "unavailable": "SOLD_OUT" }
  },
  "test_products": {
    "basic": "1006356",
    "timeslots": "1006518",
    "weekday_weekend": "1010393",
    "checkout_fields": "1006521",
    "dynamic_pricing": "1006523",
    "dynamic_timeslots": "1006524",
    "out_of_season": "1006522",
    "failing_fulfillment": "1006525"
  },
  "error_codes": {
    "rate_limit_exceeded": 429,
    "order_limit_exceeded": 429,
    "checkout_disabled": 400,
    "variants_not_available": 400,
    "timeslot_not_available": 400,
    "timeslot_missing": 400,
    "no_availability": 400,
    "order_cancellation_failed": 400,
    "resource_gone": 410,
    "unauthorized": 403,
    "reservation_error": 500,
    "temporary_error": 500
  }
}
